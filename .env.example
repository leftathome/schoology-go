# Schoology Integration Test Configuration
# Copy this file to .env.integration and fill in your values
# These values will be populated by 1Password using: op run --env-file=.env.integration -- go test -tags=integration

# Schoology host (without https://)
SCHOOLOGY_HOST=yourschool.schoology.com

# Schoology Session Credentials
# Use 1Password secret references:
# op://Private/your-item-id/field-name
SCHOOLOGY_USERNAME=op://Private/7laa2knjttv3bgx7cgb5tjxmty/username
SCHOOLOGY_PASSWORD=op://Private/7laa2knjttv3bgx7cgb5tjxmty/password

# OR if you already have session cookies extracted:
# SCHOOLOGY_SESS_ID=your-session-id
# SCHOOLOGY_CSRF_TOKEN=your-csrf-token
# SCHOOLOGY_CSRF_KEY=your-csrf-key
# SCHOOLOGY_UID=your-user-id
