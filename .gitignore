# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html

# Dependency directories
vendor/

# Go workspace file
go.work

# Environment files with secrets
.env
.env.local
.env.integration
.env.*.local

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Test data and temporary files
testdata/*.tmp
*.log

# 1Password session files
.op/

# Dolt database files (added by bd init)
.dolt/
*.db

# Playwright MCP / endpoint-discovery captures - may contain real student data
.playwright-captures/
.playwright-mcp/
*.har

# Redactor config — maps real names/UIDs/emails to placeholders and MUST stay local.
# See hack/redact.config.example.json for the schema.
hack/redact.config.json
